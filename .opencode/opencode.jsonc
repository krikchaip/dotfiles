{
  "$schema": "https://opencode.ai/config.json",

  "permission": {
    "edit": {
      // this doesn't work until the following issues are addressed
      // - https://github.com/anomalyco/opencode/issues/18441
      // - https://github.com/anomalyco/opencode/issues/5395
      "~/**": "ask",
    },

    "bash": {
      "* ~/*": "allow",
      "* $HOME/*": "allow",
    },

    "external_directory": {
      "~/**": "allow",
    },
  },
}

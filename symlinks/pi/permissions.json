{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-permission-system/main/schemas/permissions.schema.json",
  "permission": {
    "*": "allow",
    "path": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.cer": "deny",
      "*.pem": "deny",
      "*.git/*": "ask",
      "*.kube/*": "deny",
      "*.ssh/*": "deny"
    },
    "edit": {
      "*node_modules/*": "deny",
      "*dist/*": "deny",
      "*build/*": "deny"
    },
    "write": {
      "*node_modules/*": "deny",
      "*dist/*": "deny",
      "*build/*": "deny"
    },
    "bash": {
      "*agent-browser *--profile*": "deny",
      "*agent-browser *--session*": "deny",
      "*agent-browser *--session-name*": "deny",
      "*aws *": "ask",
      "*az *": "ask",
      "*curl *": "ask",
      "*git* add *": "ask",
      "*git* commit *": "ask",
      "*git* merge *": "ask",
      "*git* push *": "deny",
      "*git* reset *": "ask",
      "*git worktree remove *": "ask",
      "*kubectl *": "ask",
      "*rm *": "ask",
      "*rm -rf *": "ask",
      "*sudo *": "ask"
    },
    "external_directory": "allow"
  }
}

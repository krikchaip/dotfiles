{
  "lastChangelogVersion": "0.80.10",
  "quietStartup": false,
  "enableInstallTelemetry": false,
  "defaultProjectTrust": "always",
  "treeFilterMode": "no-tools",
  "doubleEscapeAction": "none",
  "steeringMode": "all",
  "followUpMode": "all",
  "autocompleteMaxVisible": 10,
  "theme": "everforest-dark-hard",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.6-terra",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": true,
  "enabledModels": [
    "antigravity/gemini-3.5-flash-high",
    "antigravity/gemini-3.1-pro-high",
    "antigravity/claude-opus-4-6-thinking",
    "github-copilot/gpt-5.6-terra",
    "github-copilot/gpt-5.6-sol",
    "github-copilot/claude-opus-4.8",
    "github-copilot/claude-fable-5",
    "openai-codex/gpt-5.3-codex-spark",
    "openai-codex/gpt-5.6-luna",
    "openai-codex/gpt-5.6-terra",
    "openai-codex/gpt-5.6-sol",
    "opencode/big-pickle"
  ],
  "compaction": {
    "enabled": true,
    "model": "antigravity/gemini-3.5-flash-high",
    "autoTrigger": {
      "enabled": true,
      "absoluteTokens": "100k",
      "contextWindowFamilies": {
        "200k": "100k",
        "400k": "150k",
        "1m": "200k"
      }
    }
  },
  "branchSummary": {
    "skipPrompt": true,
    "model": "antigravity/gemini-3.5-flash-high",
    "generateLabelModel": "antigravity/gemini-3.5-flash-medium"
  },
  "autoRename": {
    "enabled": true,
    "model": "antigravity/gemini-3.5-flash-high"
  },
  "skills": [
    "-skills/caveman/SKILL.md",
    "-skills/ponytail/SKILL.md"
  ],
  "extensions": [],
  "npmCommand": [
    "mise",
    "exec",
    "node@26",
    "--",
    "npm"
  ],
  "packages": [
    "git:github.com/krikchaip/pi-background-tasks@personal",
    "git:github.com/krikchaip/pi-cc-tools@personal",
    "git:github.com/krikchaip/pi-goal@personal",
    "git:github.com/krikchaip/pi-powerline-footer@personal",
    "git:github.com/krikchaip/pi-token-burden@personal",
    "git:github.com/krikchaip/pi-treex@personal",
    "npm:@gotgenes/pi-permission-system@20.6.0",
    "npm:@vanillagreen/pi-caveman",
    "npm:pi-mcp-adapter",
    "npm:pi-web-access",
    {
      "source": "npm:@victor-software-house/pi-curated-themes",
      "skills": [
        "-skills/adapt-ghostty-theme-to-pi/SKILL.md"
      ]
    },
    "packages/image-attachments",
    "packages/resume",
    "packages/provider-payload-debug"
  ],
  "vstack": {
    "extensionManager": {
      "disabledItems": [],
      "config": {
        "@vanillagreen/pi-caveman": {
          "mode": "full",
          "boundaryNormalForCommits": false
        }
      }
    }
  },
  "powerline": {
    "placement": "below",
    "sessionTitle": {
      "enabled": true,
      "alignment": "right"
    },
    "showLastPrompt": false,
    "layout": {
      "left": [
        "model",
        "thinking",
        "context_pct_plain"
      ],
      "right": [
        "extension_statuses"
      ]
    }
  },
  "powerlineShortcuts": {
    "copyEditor": "alt+c",
    "cutEditor": "alt+x",
    "editorEnd": "ctrl+shift+e",
    "editorStart": "ctrl+shift+a",
    "jumpChatBottom": "ctrl+shift+down",
    "jumpChatTop": "ctrl+shift+up",
    "jumpNextLlmMessage": "ctrl+alt+.",
    "jumpNextUserMessage": "ctrl+shift+i",
    "jumpPreviousLlmMessage": "ctrl+alt+,",
    "jumpPreviousUserMessage": "ctrl+shift+u",
    "scrollChatDown": "ctrl+down",
    "scrollChatUp": "ctrl+up",
    "stashHistory": "ctrl+alt+h"
  }
}
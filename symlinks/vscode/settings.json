{
  "agCockpit.criticalThreshold": 5,
  "agCockpit.displayMode": "webview",
  "agCockpit.groupingEnabled": false,
  "agCockpit.statusBarFormat": "percent",
  "agCockpit.warningThreshold": 25,
  "chat.fontSize": 14,
  "debug.console.fontSize": 14,
  "editor.definitionLinkOpensInPeek": true,
  "editor.fontFamily": "'FiraCode Nerd Font Mono', Menlo, Monaco, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.minimap.enabled": false,
  "editor.tabSize": 2,
  "explorer.autoReveal": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "extensions.ignoreRecommendations": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "git.allowForcePush": true,
  "git.autofetch": true,
  "git.confirmForcePush": false,
  "git.confirmSync": false,
  "markdown.preview.fontSize": 14,
  "scm.inputFontSize": 12,
  "security.workspace.trust.untrustedFiles": "open",
  "terminal.integrated.defaultProfile.osx": "Nushell",
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.macOptionIsMeta": true,
  "window.zoomLevel": 0.5,
  "windsurf.acp.enabledAgents": {
    "devin-cloud": false
  },
  "windsurf.allowCascadeAccessGitignoreFiles": true,
  "windsurf.autoContinue": 0,
  "windsurf.terminal.cascadeProfile.osx": "managed",
  "workbench.colorTheme": "Tokyo Night",
  "workbench.editorAssociations": {
    "**/rules/*.md": "default",
    "**/workflows/*.md": "default"
  }
}
// vim:ft=jsonc
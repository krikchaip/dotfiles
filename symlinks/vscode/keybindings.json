[
  // Terminal
  {
    "command": "workbench.action.terminal.kill",
    "key": "cmd+w",
    "when": "terminalFocus"
  },
  {
    "command": "workbench.action.terminal.focus",
    "key": "ctrl+t"
  },
  {
    "command": "-workbench.action.terminal.focus",
    "key": "cmd+down"
  },
  {
    "command": "workbench.action.focusActiveEditorGroup",
    "key": "ctrl+t",
    "when": "terminalFocus"
  },
  // Settings
  {
    "command": "workbench.action.openAntigravitySettings",
    "key": "alt+cmd+,",
    "when": "antigravity.agentSidePanel.active"
  },
  {
    "command": "-workbench.action.openAntigravitySettings",
    "key": "cmd+,"
  },
  {
    "command": "workbench.action.openWindsurfSettings",
    "key": "alt+cmd+,",
    "when": "windsurf.cascadePanel.active"
  },
  {
    "command": "-workbench.action.openWindsurfSettings",
    "key": "cmd+,"
  },
  // Panel
  {
    "command": "workbench.action.toggleMaximizedPanel",
    "key": "shift+cmd+j",
    "when": "panelFocus"
  },
  // Markdown
  {
    "command": "-markdown.extension.editing.toggleBold",
    "key": "cmd+b",
    "when": "editorTextFocus && !editorReadonly && editorLangId =~ /^markdown$|^rmd$|^quarto$/"
  },
  {
    "command": "-markdown.extension.editing.toggleItalic",
    "key": "cmd+i",
    "when": "editorTextFocus && !editorReadonly && editorLangId =~ /^markdown$|^rmd$|^quarto$/"
  },
  {
    "command": "-markdown.extension.editing.toggleMath",
    "key": "cmd+m",
    "when": "editorTextFocus && !editorReadonly && editorLangId =~ /^markdown$|^rmd$|^quarto$/"
  },
  {
    "command": "-markdown.extension.editing.toggleStrikethrough",
    "key": "alt+s",
    "when": "false"
  },
  {
    "command": "-markdown.extension.checkTaskList",
    "key": "alt+c",
    "when": "false"
  },
  {
    "command": "markdown.showPreview",
    "key": "ctrl+v",
    "when": "!notebookEditorFocused && editorLangId =~ /^(markdown|prompt|instructions|chatmode)$/"
  },
  {
    "command": "-markdown.showPreview",
    "key": "shift+cmd+v",
    "when": "!notebookEditorFocused && editorLangId =~ /^(markdown|prompt|instructions|chatmode)$/"
  },
  {
    "command": "markdown.extension.closePreview",
    "key": "ctrl+v",
    "when": "activeWebviewPanelId == 'markdown.preview'"
  },
  {
    "command": "-markdown.extension.closePreview",
    "key": "shift+cmd+v",
    "when": "activeWebviewPanelId == 'markdown.preview'"
  },
  // Diff Navigation
  {
    "command": "workbench.action.editor.nextChange",
    "key": "ctrl+alt+n",
    "when": "editorTextFocus && !textCompareEditorActive && quickDiffDecorationCount != '0'"
  },
  {
    "command": "-workbench.action.editor.nextChange",
    "key": "alt+f5",
    "when": "editorTextFocus && !textCompareEditorActive && quickDiffDecorationCount != '0'"
  },
  {
    "command": "workbench.action.compareEditor.nextChange",
    "key": "ctrl+alt+n",
    "when": "textCompareEditorVisible"
  },
  {
    "command": "-workbench.action.compareEditor.nextChange",
    "key": "alt+f5",
    "when": "textCompareEditorVisible"
  },
  {
    "command": "multiDiffEditor.goToNextChange",
    "key": "ctrl+alt+n",
    "when": "activeEditor == 'multiDiffEditor'"
  },
  {
    "command": "-multiDiffEditor.goToNextChange",
    "key": "alt+f5",
    "when": "activeEditor == 'multiDiffEditor'"
  },
  {
    "command": "multiDiffEditor.goToPreviousChange",
    "key": "ctrl+alt+p",
    "when": "activeEditor == 'multiDiffEditor'"
  },
  {
    "command": "-multiDiffEditor.goToPreviousChange",
    "key": "shift+alt+f5",
    "when": "activeEditor == 'multiDiffEditor'"
  },
  {
    "command": "workbench.action.compareEditor.previousChange",
    "key": "ctrl+alt+p",
    "when": "textCompareEditorVisible"
  },
  {
    "command": "-workbench.action.compareEditor.previousChange",
    "key": "shift+alt+f5",
    "when": "textCompareEditorVisible"
  },
  {
    "command": "workbench.action.editor.previousChange",
    "key": "ctrl+alt+p",
    "when": "editorTextFocus && !textCompareEditorActive && quickDiffDecorationCount != '0'"
  },
  {
    "command": "-workbench.action.editor.previousChange",
    "key": "shift+alt+f5",
    "when": "editorTextFocus && !textCompareEditorActive && quickDiffDecorationCount != '0'"
  },
  // File Explorer
  {
    "command": "workbench.files.action.showActiveFileInExplorer",
    "key": "ctrl+alt+r",
    "when": "editorFocus"
  },
  // Git
  {
    "command": "git.openFile",
    "key": "ctrl+alt+enter",
    "when": "textCompareEditorVisible"
  },
  {
    "command": "git.openChange",
    "key": "ctrl+alt+enter",
    "when": "!textCompareEditorVisible"
  },
  {
    "command": "git.stageSelectedRanges",
    "key": "ctrl+alt+g s",
    "when": "editorTextFocus && editorHasSelection && !operationInProgress && resourceScheme == 'file'"
  },
  {
    "command": "-git.stageSelectedRanges",
    "key": "cmd+k alt+cmd+s",
    "when": "editorTextFocus && !operationInProgress && resourceScheme == 'file'"
  },
  {
    "command": "git.stage",
    "key": "ctrl+alt+g s",
    "when": "editorTextFocus && !editorHasSelection && !operationInProgress && resourceScheme == 'file'"
  },
  // Extensions
  {
    "command": "workbench.view.extensions",
    "key": "ctrl+shift+x",
    "when": "viewContainer.workbench.view.extensions.enabled"
  },
  {
    "command": "-workbench.view.extensions",
    "key": "shift+cmd+x",
    "when": "viewContainer.workbench.view.extensions.enabled"
  }
]
// vim:ft=jsonc
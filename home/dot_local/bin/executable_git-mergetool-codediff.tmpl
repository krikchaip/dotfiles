#!/usr/bin/env bash

MERGED="$1"
MERGED_DIR="$(dirname "$MERGED")"
REPO_ROOT="$(git -C "$MERGED_DIR" rev-parse --show-toplevel 2>/dev/null || printf '%s' "$MERGED_DIR")"

if [[ "$MERGED" = /* ]]; then
  MERGED_ABS="$MERGED"
else
  MERGED_ABS="$REPO_ROOT/$MERGED"
fi

# Escape for Ex command argument
MERGED_ESCAPED="${MERGED_ABS//\\/\\\\}"
MERGED_ESCAPED="${MERGED_ESCAPED// /\\ }"

if [ -n "$NVIM" ] && command -v nvr >/dev/null 2>&1; then
  nvr -cc "lua require('base46').load_all_highlights()" \
    -c "CodeDiff merge $MERGED_ESCAPED" \
    -c "wincmd p"
else
  env NVIM_APPNAME=nvchad NVIM_MINIMAL=true nvim -c "lua require('base46').load_all_highlights()" \
    -c "CodeDiff merge $MERGED_ESCAPED" \
    -c "wincmd p"
fi

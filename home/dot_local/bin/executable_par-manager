#!/usr/bin/env bash

set -euo pipefail

LABEL="com.r3nniw.pi-antigravity-rotator"

PLIST_PATH="$HOME/Library/LaunchAgents/${LABEL}.plist"
SERVICE_TARGET="gui/$(id -u)/${LABEL}"
OUT_LOG="/tmp/${LABEL}.out.log"
ERR_LOG="/tmp/${LABEL}.err.log"

PAR_BIN="${PAR_BIN:-$(command -v pi-antigravity-rotator 2>/dev/null || echo "$HOME/.local/share/mise/installs/npm-pi-antigravity-rotator/latest/bin/pi-antigravity-rotator")}"
PAR_PIDFILE="/tmp/${LABEL}.pid"
PAR_LOG="/tmp/${LABEL}.par.log"

usage() {
  cat <<'EOF'
par-manager - manage pi-antigravity-rotator LaunchAgent

Usage:
  par-manager                 Show this help
  par-manager -h|--help       Show this help
  par-manager start           Start/enable service
  par-manager kill            Stop/disable service
  par-manager restart         Restart service and flush logs
  par-manager logs [--err]    Follow stdout log (default) or stderr log
  par-manager status          Show service status
  par-manager login           Interactive login helper
EOF
}

log_event() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') [par-manager] $*" >> "$OUT_LOG"
}

# ---------- PAR process management (direct, not via launchd) ----------

par_pid() {
  if [ -f "$PAR_PIDFILE" ]; then
    local pid
    pid=$(cat "$PAR_PIDFILE")

    if kill -0 "$pid" 2>/dev/null; then
      echo "$pid"
      return 0
    fi

    rm -f "$PAR_PIDFILE"
  fi

  return 1
}

PAR_STATE_CHANGED=""

par_start() {
  PAR_STATE_CHANGED=""

  if pid=$(par_pid); then
    log_event "PAR already running (pid $pid)"
    return 0
  fi

  nohup "$PAR_BIN" start >> "$PAR_LOG" 2>&1 &

  local new_pid=$!

  echo "$new_pid" > "$PAR_PIDFILE"
  log_event "PAR started (pid $new_pid)"

  PAR_STATE_CHANGED="1"
}

par_kill() {
  PAR_STATE_CHANGED=""

  if pid=$(par_pid); then
    kill "$pid" 2>/dev/null || true

    local i=0
    while kill -0 "$pid" 2>/dev/null && [ $i -lt 10 ]; do
      sleep 0.5
      i=$((i + 1))
    done

    kill -9 "$pid" 2>/dev/null || true
    rm -f "$PAR_PIDFILE"
    log_event "PAR killed (pid $pid)"

    PAR_STATE_CHANGED="1"
  else
    log_event "PAR not running, nothing to kill"
  fi
}

notify() {
  local msg="$1"
  osascript -e "display notification \"$msg\" with title \"PAR Manager\"" 2>/dev/null || true
}

# ---------- sleepwatcher hooks (internal, called by launchd plist) ----------

on_sleep() {
  log_event "Event: sleep/display-sleep"
  par_kill

  # [ -n "$PAR_STATE_CHANGED" ] && notify "System sleeping — PAR process stopped."
}

on_wake() {
  log_event "Event: wake/display-wake/idle-resume"
  par_start

  # [ -n "$PAR_STATE_CHANGED" ] && notify "Resuming — PAR process started."
}

on_idle() {
  log_event "Event: idle timeout"
  par_kill

  # [ -n "$PAR_STATE_CHANGED" ] && notify "Idle detected — PAR process stopped."
}

# ---------- public commands ----------

require_plist() {
  if [ ! -f "$PLIST_PATH" ]; then
    echo "Error: plist not found: $PLIST_PATH" >&2
    echo "Apply chezmoi first so LaunchAgent is installed." >&2
    exit 1
  fi
}

service_state() {
  launchctl print "$SERVICE_TARGET" 2>/dev/null \
    | awk -F'= ' '/^[[:space:]]*state = / { gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2); print $2; exit }'
}

start_service() {
  require_plist

  local state=""
  if launchctl print "$SERVICE_TARGET" >/dev/null 2>&1; then
    state="$(service_state || true)"
    if [ "$state" = "running" ]; then
      echo "Already running: $SERVICE_TARGET"
      return 0
    fi
  fi

  # Re-enable first. If service was disabled (e.g. via `par-manager kill`),
  # bootstrap can fail with opaque I/O errors until re-enabled.
  launchctl enable "$SERVICE_TARGET" >/dev/null 2>&1 || true

  if launchctl print "$SERVICE_TARGET" >/dev/null 2>&1; then
    launchctl kickstart -k "$SERVICE_TARGET" >/dev/null 2>&1 || true
  else
    launchctl bootstrap "gui/$(id -u)" "$PLIST_PATH"
    launchctl kickstart -k "$SERVICE_TARGET" >/dev/null 2>&1 || true
  fi

  # Also start PAR immediately since user is active
  par_start

  state="$(service_state || true)"
  if [ "$state" = "running" ]; then
    echo "Started: $SERVICE_TARGET"
  else
    echo "Starting: $SERVICE_TARGET"
  fi
}

kill_service() {
  par_kill

  launchctl disable "$SERVICE_TARGET" >/dev/null 2>&1 || true
  launchctl bootout "gui/$(id -u)" "$PLIST_PATH" >/dev/null 2>&1 || true

  echo "Stopped/disabled: $SERVICE_TARGET"
}

restart_service() {
  kill_service
  rm -f "$OUT_LOG" "$ERR_LOG" "$PAR_LOG"
  start_service

  echo "Logs flushed: $OUT_LOG, $ERR_LOG"
}

logs_service() {
  local file="$OUT_LOG"
  if [ "${1:-}" = "--err" ]; then
    file="$ERR_LOG"
  elif [ -n "${1:-}" ]; then
    echo "Unknown logs option: $1" >&2
    usage
    exit 1
  fi

  echo "Following: $file"
  tail -n 200 -F "$file"
}

status_service() {
  echo "Label:        $LABEL"
  echo "Plist:        $PLIST_PATH"
  echo "Stdout log:   $OUT_LOG"
  echo "Stderr log:   $ERR_LOG"
  echo "PAR log:      $PAR_LOG"

  if [ -f "$PLIST_PATH" ]; then
    echo "Plist exists: yes"
  else
    echo "Plist exists: no"
  fi

  echo
  echo "=== Sleepwatcher (launchd) ==="
  if launchctl print "$SERVICE_TARGET" >/dev/null 2>&1; then
    launchctl print "$SERVICE_TARGET" | grep -E "^\t(state =|pid =|last exit code =|path =|program =|disabled =)" || true
  else
    echo "Service not currently loaded in launchd."
    if launchctl print-disabled "gui/$(id -u)" 2>/dev/null | grep -q "\"$LABEL\" => true"; then
      echo "Disabled: true"
    fi
  fi

  echo
  echo "=== PAR Process ==="
  if pid=$(par_pid); then
    echo "Running (pid $pid)"
  else
    echo "Not running"
  fi
}

login_service() {
  local accounts_file="$HOME/.pi-antigravity-rotator/accounts.json"
  local port=51200
  if [ -f "$accounts_file" ]; then
    port=$(jq -r '.proxyPort // 51200' "$accounts_file")
  fi

  local rotator_bin
  rotator_bin="$(command -v pi-antigravity-rotator || echo "$HOME/.local/share/mise/installs/npm-pi-antigravity-rotator/latest/bin/pi-antigravity-rotator")"

  while true; do
    local api_json
    api_json=$(curl -s --max-time 2 "http://localhost:${port}/api/status" || true)

    echo ""
    echo "=== Logged In Accounts ==="
    if [ -n "$api_json" ] && echo "$api_json" | jq -e '.accounts' >/dev/null 2>&1; then
      echo "$api_json" | jq -r '.accounts[] | " - \(.email) [\(.status | ascii_upcase)] (label: \(.label // "none"))"'
    elif [ -f "$accounts_file" ]; then
      jq -r '.accounts[] | " - \(.email) [OFFLINE] (label: \(.label // "none"))"' "$accounts_file"
    else
      echo "No accounts logged in."
    fi
    echo "=========================="
    echo ""
    echo "1) Login/Add Google account"
    echo "2) Exit"
    echo ""
    read -p "Choose option: " choice

    if [ "$choice" = "1" ]; then
      local initial_count=0
      if [ -f "$accounts_file" ]; then
        initial_count=$(jq '.accounts | length' "$accounts_file")
      fi
      local added_any=0

      while true; do
        echo ""
        echo "Starting rotator login helper..."

        PAR_LOGIN_LOG_FILE="/tmp/par-login-run.log"
        rm -f "$PAR_LOGIN_LOG_FILE"
        touch "$PAR_LOGIN_LOG_FILE"

        # Background monitor
        (
          while [ -f "$PAR_LOGIN_LOG_FILE" ]; do
            if [ -s "$PAR_LOGIN_LOG_FILE" ]; then
              local url
              url=$(grep -o -E 'https://accounts\.google\.com\S+' "$PAR_LOGIN_LOG_FILE" | head -n 1)
              if [ -n "$url" ]; then
                open "$url"
                break
              fi
            fi
            sleep 0.5
          done
        ) &
        PAR_LOGIN_MONITOR_PID=$!

        cleanup_login() {
          rm -f "${PAR_LOGIN_LOG_FILE:-}"
          if [ -n "${PAR_LOGIN_MONITOR_PID:-}" ]; then
            kill "$PAR_LOGIN_MONITOR_PID" 2>/dev/null || true
          fi
        }
        trap cleanup_login EXIT INT TERM

        # Run the command with stdin/stdout connected
        "$rotator_bin" login 2>&1 | tee "$PAR_LOGIN_LOG_FILE"

        trap - EXIT INT TERM
        cleanup_login
        wait "${PAR_LOGIN_MONITOR_PID:-}" 2>/dev/null || true

        local current_count=0
        if [ -f "$accounts_file" ]; then
          current_count=$(jq '.accounts | length' "$accounts_file")
        fi

        if [ "$current_count" -gt "$initial_count" ]; then
          echo ""
          echo "Account added successfully."
          added_any=1
          initial_count=$current_count
        else
          echo ""
          echo "Login finished."
        fi

        read -p "Do you want to log in to another account? (y/N): " cont
        if [[ ! "$cont" =~ ^[yY]$ ]]; then
          break
        fi
      done

      if [ "$added_any" -eq 1 ]; then
        echo ""
        echo "New account(s) detected."
        read -p "Restart background service to apply changes? (Y/n): " restart
        if [[ ! "$restart" =~ ^[nN]$ ]]; then
          echo "Restarting service..."
          restart_service
        fi
      fi

    elif [ "$choice" = "2" ] || [ -z "$choice" ]; then
      break
    else
      echo "Invalid choice."
    fi
  done
}

main() {
  case "${1:-}" in
    ""|-h|--help)
      usage
      ;;
    start)
      start_service
      ;;
    kill)
      kill_service
      ;;
    restart)
      restart_service
      ;;
    logs)
      logs_service "${2:-}"
      ;;
    status)
      status_service
      ;;
    login)
      login_service
      ;;

    # Internal hooks called by sleepwatcher (via launchd plist)
    _on-sleep) on_sleep ;;
    _on-wake)  on_wake  ;;
    _on-idle)  on_idle  ;;

    *)
      echo "Unknown command: $1" >&2
      echo >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"

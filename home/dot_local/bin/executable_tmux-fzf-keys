#!/usr/bin/env bash

# tmux-fzf-keys - select and execute a tmux keybinding

# Build a 3-column table: [key combo] \t [desc] \t [actual tmux fn]
table=$(awk '
NR==FNR {
  # Parse `tmux lsk -T prefix`
  for(i=1; i<=NF; i++) {
    if ($i == "prefix") {
      key = $(i+1)
      for(j=1; j<=i+1; j++) $j=""
      sub(/^ +/, "", $0)
      cmd[key] = $0
      break
    }
  }
  next
}
{
  # Parse `tmux lsk -N`
  key = $2
  desc = $0

  # remove the "C-; Tab" part from desc to just get the note text
  sub(/^[^ ]+ +[^ ]+ +/, "", desc)

  # output: C-; Tab \t desc \t command
  printf "%-12s\t%-40s\t%s\n", $1 " " $2, desc, cmd[key]
}' <(tmux lsk -T prefix) <(tmux lsk -N))

# Select using fzf. Display columns 1 and 2, but output the full line.
target=$(echo "$table" | fzf -d '\t' --with-nth 1,2 --height=~100% --header='Select keybinding: (Esc to cancel)')

[[ -z "$target" ]] && exit 0

# Extract selected key from col1: "C-; <key>"
key=$(echo "$target" | awk -F'\t' '{print $1}' | awk '{print $2}')

# Re-trigger real tmux binding after popup exits.
# Put client into prefix table, then send only selected key.
client_name=$(tmux display-message -p '#{client_name}')

printf -v inject_cmd 'sleep 0.10; tmux switch-client -T prefix -c %q; tmux send-keys -K -c %q %q' \
  "$client_name" "$client_name" "$key"

tmux run-shell -b "$inject_cmd"

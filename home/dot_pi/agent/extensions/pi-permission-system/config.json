{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-permission-system/main/schemas/permissions.schema.json",

  "permission": {
    "*": "allow",

    "path": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.pem": "deny",
      "*.cer": "deny",
      "~/.ssh*": "deny"
    },

    "bash": {
      "aws *": "ask",
      "az *": "ask",
      "curl *": "ask",
      "git commit *": "deny",
      "git merge *": "ask",
      "git push *": "deny",
      "git reset *": "ask",
      "git worktree remove *": "ask",
      "kubectl *": "ask",
      "rm *": "ask",
      "rm -rf *": "deny",
      "sudo *": "ask"
    },

    "external_directory": "allow"
  }
}

{
  "$schema": "https://opencode.ai/tui.json",

  "plugin": [
    "opencode-rules@0", // https://github.com/frap129/opencode-rules
  ],

  "theme": "tokyonight",

  "keybinds": {
    "leader": "ctrl+o",

    "editor_open": "ctrl+return,alt+return",

    "session_new": "ctrl+n",
    "session_list": "alt+l",
    "session_timeline": "ctrl+g",
    "session_fork": "<leader>f",
    "session_rename": "ctrl+r",
    "session_child_first": "alt+shift+down",
    "session_child_cycle": "alt+shift+right",
    "session_child_cycle_reverse": "alt+shift+left",
    "session_parent": "alt+shift+up",

    "messages_first": "ctrl+shift+up,home",
    "messages_last": "ctrl+shift+down,end",
    "messages_next": "ctrl+down",
    "messages_previous": "ctrl+up",
    "messages_copy": "ctrl+y",
    "messages_undo": "alt+u",
    "messages_redo": "alt+r",
    "messages_toggle_conceal": "none",

    "model_list": "alt+m",

    "display_thinking": "alt+k",
  },
}

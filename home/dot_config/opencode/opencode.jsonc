{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,

  "plugin": [
    "opencode-antigravity-auth@1", // https://github.com/NoeFabris/opencode-antigravity-auth
    "@tarquinen/opencode-dcp@3", // https://github.com/Opencode-DCP/opencode-dynamic-context-pruning
    "opencode-pty@0", // https://github.com/shekohex/opencode-pty
    "@mohak34/opencode-notifier@0", // https://github.com/mohak34/opencode-notifier
    "@plannotator/opencode@0", // https://github.com/backnotprop/plannotator
    "opencode-scheduler@1", // https://github.com/different-ai/opencode-scheduler
    "opencode-agent-memory@0", // https://github.com/joshuadavidthomas/opencode-agent-memory
    "@slkiser/opencode-quota@2", // https://github.com/slkiser/opencode-quota
    "opencode-rules@0", // https://github.com/frap129/opencode-rules
  ],

  "model": "opencode/big-pickle",
  "small_model": "opencode/gpt-5-nano",

  "enabled_providers": ["opencode", "openrouter", "google", "github-copilot"],
  "provider": {
    "openrouter": {
      "models": {
        "openai/gpt-oss-20b": {
          "options": { "provider": { "only": ["wandb/fp4"] } },
        },
        "openai/gpt-oss-120b": {
          "options": { "provider": { "only": ["groq"] } },
        },
        "qwen/qwen3.5-flash-02-23": {
          "id": "qwen/qwen3.5-flash-02-23",
          "name": "Qwen3.5 Flash 2026-02-23",
          "limit": { "context": 1000000, "output": 65535 },
        },
      },
    },
    "google": {
      "whitelist": [
        "antigravity-gemini-3.1-pro",
        "antigravity-gemini-3-flash",
        "antigravity-claude-sonnet-4-6",
        "antigravity-claude-opus-4-6-thinking",
      ],
      "models": {
        "antigravity-gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro (Antigravity)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "variants": {
            "low": { "thinkingLevel": "low" },
            "high": { "thinkingLevel": "high" },
          },
        },
        "antigravity-gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "variants": {
            "minimal": { "thinkingLevel": "minimal" },
            "low": { "thinkingLevel": "low" },
            "medium": { "thinkingLevel": "medium" },
            "high": { "thinkingLevel": "high" },
          },
        },
        "antigravity-claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Antigravity)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "antigravity-claude-opus-4-6-thinking": {
          "name": "Claude Opus 4.6 Thinking (Antigravity)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "variants": {
            "low": { "thinkingConfig": { "thinkingBudget": 8192 } },
            "max": { "thinkingConfig": { "thinkingBudget": 32768 } },
          },
        },
      },
    },
  },

  "default_agent": "agentic",
  "agent": {
    // disable builtin agents
    "build": { "disable": true },
    "plan": { "disable": true },
    "general": { "disable": true },
    "explore": { "disable": true },

    // custom agents
    "browser": { "model": "google/antigravity-gemini-3-flash" },
    "conversation": { "model": "openrouter/qwen/qwen3.5-flash-02-23" },
    "schedule": { "model": "google/antigravity-gemini-3-flash" },

    // mcp agents
    "atlassian": { "model": "google/antigravity-gemini-3-flash" },
    "github": { "model": "google/antigravity-gemini-3-flash" },
    "obsidian": { "model": "google/antigravity-gemini-3-flash" },
  },

  "permission": {
    "mcp-*": "deny",

    // prefer bash-first `read|ripgrep|find|ls` so `rtk` can rewrite commands.
    // except for `read`, which is required by edit tools
    "grep": "deny",
    "glob": "deny",
    "list": "deny",

    // subagent-specific
    "skill": {
      "agent-browser": "deny",
      "browser-context": "deny",
      "zettelkasten": "deny",
      "conversation-manager": "deny",
    },

    // [plannotator]
    "submit_plan": "deny", // only submit plans after asking series of questions

    // [antigravity-auth]
    "google_search": "deny", // use EXA search instead

    // [scheduler]
    "schedule_job": "deny", // create a new scheduled job
    "list_jobs": "deny", // list all scheduled jobs
    "get_version": "deny", // show scheduler and opencode versions
    "get_skill": "deny", // get built-in skill templates (best practices)
    "install_skill": "deny", // install a built-in skill into your repo
    "get_job": "deny", // fetch job details and metadata
    "update_job": "deny", // update an existing job
    "delete_job": "deny", // remove a scheduled job
    "cleanup_global": "deny", // remove scheduler artifacts across all scopes (dry-run by default)
    "run_job": "deny", // execute a job immediately (fire-and-forget)
    "job_logs": "deny", // view the latest logs from a job

    "bash": {
      "* ~/*": "ask",
      "* $HOME/*": "ask",
      "* *../*": "deny",

      "aws *": "ask",
      "az *": "ask",
      "curl *": "ask",
      "git merge *": "ask",
      "git push*": "deny",
      "git reset *": "ask",
      "git worktree remove *": "ask",
      "kubectl *": "ask",
      "rm *": "ask",
    },

    "external_directory": {
      "/tmp/pngpaste/**": "allow", // screenshots
    },
  },

  "mcp": {
    "mcp-github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": { "Authorization": "Bearer {env:GITHUB_MCP_PAT}" },
    },
    "mcp-atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
    },
    "mcp-obsidian": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "--",
        "bunx",
        "--bun",
        "@mauricio.wolff/mcp-obsidian@latest",
        "{env:HOME}/Desktop/zettelkasten",
      ],
    },
  },

  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"],
  },

  "experimental": {
    // https://github.com/slkiser/opencode-quota#configuration-reference
    "quotaToast": {
      "enableToast": false,
      "googleModels": ["G3FLASH", "G3PRO", "CLAUDE"],
    },
  },
}

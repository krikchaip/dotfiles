{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "instructions": [".agent/rules/*.md", ".agents/rules/*.md"],
  "model": "opencode/minimax-m2.5-free",
  "small_model": "opencode/gpt-5-nano",
  "default_agent": "ask",
  "agent": {
    "plan": { "model": "openrouter/anthropic/claude-opus-4.6" },
    "build": { "model": "openrouter/google/gemini-3-flash-preview" },
    "general": { "model": "openrouter/anthropic/claude-sonnet-4.6" },
    "explore": { "model": "openrouter/google/gemini-3-flash-preview" }
  },
  "tools": {
    "mcp-*": false
  },
  "permission": {
    "bash": {
      "*": "allow",
      "aws *": "ask",
      "az *": "ask",
      "curl *": "ask",
      "git merge *": "ask",
      "git push *": "deny",
      "git reset *": "ask",
      "git worktree remove *": "ask",
      "kubectl": "ask",
      "rm *": "ask"
    },
    "external_directory": {
      "/tmp/pngpaste/**": "allow"
    }
  },
  "mcp": {
    "mcp-github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": { "Authorization": "Bearer {env:GITHUB_MCP_PAT}" }
    },
    "mcp-atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "headers": { "Authorization": "Basic {env:ATLASSIAN_MCP_TOKEN}" }
    },
    "mcp-obsidian": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "--",
        "bunx",
        "--bun",
        "@mauricio.wolff/mcp-obsidian@latest",
        "{env:HOME}/Desktop/zettelkasten"
      ]
    }
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  }
}

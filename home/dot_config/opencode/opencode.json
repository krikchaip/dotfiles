{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,

  "instructions": [".agent/rules/*.md", ".agents/rules/*.md"],

  "model": "opencode/big-pickle",
  "small_model": "opencode/gpt-5-nano",

  "enabled_providers": ["openrouter", "github-copilot", "opencode"],
  "provider": {},

  "default_agent": "ask",
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true },
    "general": { "disable": true },
    "explore": { "disable": true }
  },

  "permission": {
    "mcp-*": "deny",
    "bash": {
      "*": "allow",
      "aws *": "ask",
      "az *": "ask",
      "curl *": "ask",
      "git merge *": "ask",
      "git push *": "deny",
      "git reset *": "ask",
      "git worktree remove *": "ask",
      "kubectl *": "ask",
      "rm *": "ask"
    },
    "external_directory": {
      "/tmp/pngpaste/**": "allow"
    }
  },

  "mcp": {
    "mcp-github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": { "Authorization": "Bearer {env:GITHUB_MCP_PAT}" }
    },
    "mcp-atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "headers": { "Authorization": "Basic {env:ATLASSIAN_MCP_TOKEN}" }
    },
    "mcp-obsidian": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "--",
        "bunx",
        "--bun",
        "@mauricio.wolff/mcp-obsidian@latest",
        "{env:HOME}/Desktop/zettelkasten"
      ]
    }
  },

  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  }
}

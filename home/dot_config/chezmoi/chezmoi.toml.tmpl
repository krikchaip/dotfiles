[cd]
  command = "{{ .config.shell }}"

[diff]
  command = "env"
  args = ["NVIM_APPNAME=nvchad", "nvim", "-d", '{{ "{{" }} .Target {{ "}}" }}', '{{ "{{" }} .Destination {{ "}}" }}']
  exclude = ["scripts", "externals"]

[merge]
  command = "env"
  args = ["NVIM_APPNAME=nvchad", "nvim", "-d", '{{ "{{" }} .Source {{ "}}" }}', '{{ "{{" }} .Destination {{ "}}" }}', '{{ "{{" }} .Target {{ "}}" }}']

[edit]
  command = "nvim"

[[textconv]]
  command = "plutil"
  args = ["-convert", "xml1", "-o", "-", "-"]
  pattern = "**/*.plist"

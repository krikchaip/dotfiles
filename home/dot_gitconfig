[include]
  path = ~/.config/delta/themes.gitconfig
  path = ~/.local/share/tokyonight/extras/delta/tokyonight_storm.gitconfig

[core]
  editor = nvr -cc vsplit -c 'set winfixbuf bufhidden=delete | nnoremap <buffer> q <C-w>q' --remote-send '<M-g>' --remote-wait-silent

[user]
  name = krikchaip
  email = krikchai.p@gmail.com

[diff]
  ; ref: https://dandavison.github.io/delta/color-moved-support.html
  colorMoved = default

  ; ref: https://github.com/esmuellert/codediff.nvim#git-diff-tool
  tool = codediff

[difftool.codediff]
  cmd = "env NVIM_APPNAME=nvchad NVIM_MINIMAL=true nvim \"$LOCAL\" \"$REMOTE\" -c \"lua require('base46').load_all_highlights()\" -c \"CodeDiff file $LOCAL $REMOTE\""

[merge]
  ; ref: https://github.com/esmuellert/codediff.nvim#git-merge-tool
  tool = codediff

  ; ref: https://dandavison.github.io/delta/merge-conflicts.html
  conflictStyle = zdiff3

[mergetool.codediff]
  cmd = "env NVIM_APPNAME=nvchad NVIM_MINIMAL=true nvim \"$MERGED\" -c \"lua require('base46').load_all_highlights()\" -c \"CodeDiff merge $MERGED\""

[interactive]
  ; ref: https://dandavison.github.io/delta/full---help-output.html?highlight=interactive#full---help-output
  diffFilter = delta --color-only

[delta]
  syntax-theme = tokyonight

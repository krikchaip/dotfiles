{
  "mcpServers": {
    "atlassian": {
      "disabled": true,
      "disabledTools": [
        "addWorklogToJiraIssue",
        "createConfluenceFooterComment",
        "createConfluenceInlineComment",
        "getConfluenceSpaces",
        "getJiraProjectIssueTypesMetadata",
        "getJsmOpsAlerts",
        "getJsmOpsScheduleInfo",
        "getJsmOpsTeamInfo",
        "getTransitionsForJiraIssue",
        "getVisibleJiraProjects",
        "lookupJiraAccountId",
        "searchConfluenceUsingCql",
        "searchJiraIssuesUsingJql",
        "transitionJiraIssue",
        "updateJsmOpsAlert"
      ],
      "headers": {
        "Authorization": "Basic {{ env "ATLASSIAN_MCP_TOKEN" }}"
      },
      "serverUrl": "https://mcp.atlassian.com/v1/mcp"
    },
    "github": {
      "disabled": true,
      "disabledTools": [
        "add_comment_to_pending_review",
        "assign_copilot_to_issue",
        "create_pull_request_with_copilot",
        "create_repository",
        "delete_file",
        "fork_repository",
        "get_copilot_job_status",
        "get_label",
        "get_latest_release",
        "get_team_members",
        "get_teams",
        "list_issue_types",
        "merge_pull_request",
        "pull_request_review_write",
        "request_copilot_review",
        "search_users",
        "sub_issue_write",
        "update_pull_request_branch"
      ],
      "headers": {
        "Authorization": "Bearer {{ env "GITHUB_MCP_PAT" }}"
      },
      "serverUrl": "https://api.githubcopilot.com/mcp"
    },
    "obsidian": {
      "args": [
        "exec",
        "--",
        "bunx",
        "--bun",
        "@mauricio.wolff/mcp-obsidian@latest",
        "{{ .chezmoi.homeDir }}/Desktop/zettelkasten"
      ],
      "command": "mise",
      "disabled": true,
      "disabledTools": [
        "delete_note",
        "get_notes_info",
        "get_vault_stats",
        "move_file"
      ]
    }
  }
}

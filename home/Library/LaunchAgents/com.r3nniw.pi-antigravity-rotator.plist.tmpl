<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.r3nniw.pi-antigravity-rotator</string>

    <key>ProgramArguments</key>
    <array>
      <string>{{ .chezmoi.homeDir }}/.local/share/mise/installs/npm-pi-antigravity-rotator/latest/bin/pi-antigravity-rotator</string>
      <string>start</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
      <key>PATH</key>
      <string>{{ .chezmoi.homeDir }}/.local/share/mise/installs/node/latest/bin:{{ .chezmoi.homeDir }}/.local/share/mise/shims:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>5</integer>

    <key>StandardOutPath</key>
    <string>/tmp/com.r3nniw.pi-antigravity-rotator.out.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/com.r3nniw.pi-antigravity-rotator.err.log</string>
  </dict>
</plist>
